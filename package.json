{
  "name": "dionysus-program",
  "private": true,
  "scripts": {
    "build:site": "bash ./build-site.sh",
    "check": "bash ./agent/check.sh",
    "social:plan-week": "node social/cli/plan-week.js",
    "social:scan-timely": "node social/cli/scan-timely.js",
    "social:build-brief": "node social/cli/build-brief.js",
    "social:generate-candidates": "node social/cli/generate-candidates.js",
    "social:score-candidates": "node social/cli/score-candidates.js",
    "social:publish-due": "node social/cli/publish-due.js",
    "social:x-oauth2-token": "node social/cli/x-oauth2-token.js",
    "social:cost-per-post-day": "node social/cli/cost-per-post-day.js",
    "social:compare-writers": "node social/cli/compare-writers.js",
    "social:best-of-n-bakeoff": "node social/cli/best-of-n-bakeoff.js",
    "social:multi-judge-bakeoff": "node social/cli/multi-judge-bakeoff.js",
    "social:import-linkedin-analytics": "node social/cli/import-linkedin-analytics.js",
    "social:rebuild-memory": "node social/cli/rebuild-memory.js",
    "social:validate-state": "node social/cli/validate-state.js",
    "social:replay-run": "node social/cli/replay-run.js",
